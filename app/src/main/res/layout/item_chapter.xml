<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="16dp"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_item_rounded"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    >

    <TextView
        android:id="@+id/tvChapterName"
        android:textSize="22sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvChapterCount"
        app:layout_constraintStart_toStartOf="parent"
        android:textColor="@color/backgroundColor"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="6dp"
        />

    <TextView
        android:id="@+id/tvChapterCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 cartas"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvChapterName"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvChapterName"
        android:layout_marginTop="12dp"

        android:textColor="@color/backgroundColor"
        android:alpha="0.7"
        />

</androidx.constraintlayout.widget.ConstraintLayout>